# Copy to .env.local and fill in from your Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — never exposed to the browser. From Supabase Settings → API (service_role).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Any secret PIN you choose; required for all admin actions.
ADMIN_PIN=choose-a-pin
